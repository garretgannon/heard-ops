{
  "name": "JobCode",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Job Code Name"
    },
    "department": {
      "type": "string",
      "title": "Department",
      "enum": [
        "BOH",
        "FOH",
        "Bar",
        "Management"
      ],
      "enumNames": [
        "Back of House",
        "Front of House",
        "Bar",
        "Management"
      ]
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "isActive": {
      "type": "boolean",
      "title": "Active",
      "default": true
    },
    "assignedStations": {
      "type": "array",
      "title": "Assigned Station IDs",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "required": [
    "name",
    "department"
  ]
}