{
  "name": "OpeningChecklist",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "title": "Date"
    },
    "task_name": {
      "type": "string",
      "title": "Task Name"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "assigned_to_name": {
      "type": "string",
      "title": "Assigned To (Name)"
    },
    "assigned_to_email": {
      "type": "string",
      "title": "Assigned To (Email)"
    },
    "area": {
      "type": "string",
      "title": "Area",
      "enum": [
        "FOH",
        "BOH",
        "Bar",
        "Kitchen",
        "Management",
        "General"
      ],
      "enumNames": [
        "FOH",
        "BOH",
        "Bar",
        "Kitchen",
        "Management",
        "General"
      ]
    },
    "is_critical": {
      "type": "boolean",
      "title": "Critical Item",
      "default": false
    },
    "is_template": {
      "type": "boolean",
      "title": "Template (reuse daily)",
      "default": false
    },
    "source_template_id": {
      "type": "string",
      "title": "Source Template ID"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "pending",
        "in_progress",
        "completed"
      ],
      "enumNames": [
        "Pending",
        "In Progress",
        "Completed"
      ],
      "default": "pending"
    },
    "completed_at": {
      "type": "string",
      "title": "Completed At (ISO)"
    },
    "completed_by": {
      "type": "string",
      "title": "Completed By"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    },
    "sort_order": {
      "type": "number",
      "title": "Sort Order",
      "default": 0
    }
  },
  "required": [
    "task_name"
  ]
}