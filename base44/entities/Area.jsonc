{
  "name": "Area",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Area Name"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "color": {
      "type": "string",
      "title": "Color Tag"
    },
    "owner_id": {
      "type": "string",
      "title": "Owner Employee ID"
    },
    "owner_name": {
      "type": "string",
      "title": "Owner Name (denormalized)"
    },
    "isActive": {
      "type": "boolean",
      "title": "Active",
      "default": true
    },
    "sortOrder": {
      "type": "number",
      "title": "Sort Order",
      "default": 0
    }
  },
  "required": [
