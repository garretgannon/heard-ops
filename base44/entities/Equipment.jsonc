      "type": "string",
      "title": "Department"
    },
    "area": {
      "type": "string",
      "title": "Area"
    },
    "station": {
      "type": "string",
      "title": "Station"
    },
    "vendorId": {
      "type": "string",
      "title": "Vendor / Repair Contact ID"
    },
    "modelNumber": {
      "type": "string",
      "title": "Model Number"
    },
    "serialNumber": {
      "type": "string",
      "title": "Serial Number"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    },
    "requiresTemperatureLog": {
      "type": "boolean",
      "title": "Requires Temperature Log",
      "default": false
