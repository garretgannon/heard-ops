        "hvac",
        "water-heater",
        "other"
      ],
      "enumNames": [
        "Dish Machine",
        "3-Compartment Sink",
        "Hand Sink",
        "Walk-in Cooler",
        "Walk-in Freezer",
        "Reach-in Cooler",
