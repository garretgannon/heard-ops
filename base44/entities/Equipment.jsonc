      "type": "boolean",
      "title": "Requires Maintenance Checklist",
      "default": false
    },
    "hasQRCode": {
      "type": "boolean",
      "title": "Has QR Code",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "title": "Active",
      "default": true
    }
